{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "installCommand": "bun install --legacy-peer-deps --force",
  "buildCommand": "bunx prisma generate && bunx tsc"
}
