{
  "name": "api-chatbot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'tsx src/index.ts'",
    "build": "prisma generate && tsc",
    "postinstall": "prisma generate",
    "start": "tsx src/index.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed.ts",
    "test": "node --import tsx --test src/tests/**/*.test.ts"
  },
  "dependencies": {
    "@better-auth/infra": "^0.2.14",
    "@better-auth/prisma-adapter": "^1.1.18",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.9.0",
    "better-auth": "^1.1.18",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "multer": "^2.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.9.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0"
  }
}